generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  members   User[]
  patients  Patient[]
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  emailVerified  DateTime?
  name           String?
  password       String?
  image          String?
  role           Role          @default(FAMILY_MEMBER)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Organization (for company admins and caregivers)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // App relations
  patient           Patient?       @relation("PatientUser")
  familyOf          Patient[]      @relation("FamilyMembers")
  notifications     Notification[]
  uploadedDocuments Document[]     @relation("UploadedDocuments")
  assignedTasks     Task[]         @relation("AssignedTasks")
  caregiverShifts          Shift[]           @relation("CaregiverShifts")
  scheduledShifts          ScheduledShift[]  @relation("CaregiverScheduledShifts")
  shiftRequests            ShiftRequest[]    @relation("ShiftRequests")
  coveredShiftRequests     ShiftRequest[]    @relation("CoveredShifts")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Patient {
  id               String        @id @default(cuid())
  userId           String        @unique
  user             User          @relation("PatientUser", fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth      DateTime?
  medicalNotes     String?
  emergencyContact String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Organization (for company-managed patients)
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])

  // Care Profile (structured data from discharge documents or manual entry)
  dischargeInfo        Json?   // DischargeInfo
  exerciseGuidelines   Json?   // ExerciseGuidelines
  dietRestrictions     Json?   // DietRestrictions
  warningSigns         Json?   // WarningSigns
  careContacts         Json?   // CareContact[]
  followUpAppointments Json?   // FollowUpAppointment[]
  allergies            Json?   // { items: [{ substance, reaction, severity? }] }
  conditions           Json?   // { items: [{ name, status?, notes? }] }
  healthHistory        Json?   // { items: [{ event, date?, notes? }] }
  illnessHistory       Json?   // { items: [{ illness, date?, notes? }] }

  // Family visibility settings (admin-controlled)
  familyCanViewTasks   Boolean @default(true)
  familyCanViewMeds    Boolean @default(true)
  familyCanViewMetrics Boolean @default(true)
  familyCanViewShifts  Boolean @default(true)

  // Relations
  familyMembers   User[]         @relation("FamilyMembers")
  tasks           Task[]
  medications     Medication[]
  documents       Document[]
  inviteCodes     InviteCode[]
  shifts           Shift[]
  scheduledShifts  ScheduledShift[]
  healthMetrics    HealthMetric[]
  careRequests     CareRequest[]
}

model InviteCode {
  id              String   @id @default(cuid())
  code            String   @unique
  patientId       String?  // null for org caregiver invites
  patient         Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organizationId  String?  // set for org caregiver invites
  targetEmail     String?  // email the invite was sent to (for org invites)
  inviteType      String   @default("PATIENT") // "PATIENT" | "CAREGIVER_ORG" | "FAMILY"
  createdBy       String   // User ID who created the invite
  usedBy          String?  // User ID who used the invite
  usedAt          DateTime?
  expiresAt       DateTime
  createdAt       DateTime @default(now())
}

model Task {
  id          String     @id @default(cuid())
  patientId   String
  patient     Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  dueTime     String?    // Time of day (e.g., "09:00", "14:30")
  isRecurring Boolean    @default(false)
  recurrence  String?    // "daily", "weekly", "monthly"
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(PENDING)
  category    TaskCategory @default(OTHER)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Link to medication if this is a medication task
  medicationId String?
  medication   Medication? @relation(fields: [medicationId], references: [id])

  // Task assignment
  assignedToId String?
  assignedTo   User?      @relation("AssignedTasks", fields: [assignedToId], references: [id])

  notifications Notification[]
}

model Medication {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name         String
  dosage       String
  frequency    String   // "once daily", "twice daily", "every 8 hours", etc.
  instructions String?
  startDate    DateTime
  endDate      DateTime?
  prescriber   String?
  pharmacy     String?
  refillDate   DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Extracted from document
  documentId   String?
  document     Document? @relation(fields: [documentId], references: [id])

  tasks        Task[]
}

model Document {
  id            String       @id @default(cuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fileName      String
  fileUrl       String
  fileType      String
  rawText       String? // OCR extracted text
  processedData Json?        // Structured data extracted from OCR
  summary       String?      // AI-generated plain-English summary
  documentType  DocumentType @default(OTHER)
  uploadedAt    DateTime     @default(now())
  processedAt   DateTime?

  // Who uploaded the document
  uploadedById  String?
  uploadedBy    User?        @relation("UploadedDocuments", fields: [uploadedById], references: [id])

  medications   Medication[]
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?            @relation(fields: [taskId], references: [id])
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  sentAt    DateTime         @default(now())
  readAt    DateTime?

  // Delivery status
  emailSent Boolean @default(false)
  pushSent  Boolean @default(false)
}

model Shift {
  id          String    @id @default(cuid())
  caregiverId String
  caregiver   User      @relation("CaregiverShifts", fields: [caregiverId], references: [id])
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clockIn     DateTime  @default(now())
  clockOut    DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
}

model ScheduledShift {
  id          String               @id @default(cuid())
  caregiverId String
  caregiver   User                 @relation("CaregiverScheduledShifts", fields: [caregiverId], references: [id])
  patientId   String
  patient     Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime
  status      ScheduledShiftStatus @default(SCHEDULED)
  notes       String?
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  requests      ShiftRequest[] @relation("ShiftRequests")
  offerRequests ShiftRequest[] @relation("OfferedShifts")
}

model ShiftRequest {
  id               String             @id @default(cuid())
  requesterId      String
  requester        User               @relation("ShiftRequests", fields: [requesterId], references: [id])
  type             ShiftRequestType
  status           ShiftRequestStatus @default(PENDING)

  scheduledShiftId String?
  scheduledShift   ScheduledShift?    @relation("ShiftRequests", fields: [scheduledShiftId], references: [id])

  offeredShiftId   String?
  offeredShift     ScheduledShift?    @relation("OfferedShifts", fields: [offeredShiftId], references: [id])

  requestDate      DateTime?
  coveredById      String?
  coveredBy        User?              @relation("CoveredShifts", fields: [coveredById], references: [id])

  message          String?
  adminNote        String?
  resolvedById     String?
  resolvedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model HealthMetric {
  id               String   @id @default(cuid())
  patientId        String
  patient          Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type             String   // "blood_pressure", "blood_glucose", "weight", "heart_rate", "oxygen_saturation", "temperature"
  value            String   // "120/80", "95", "165.5"
  unit             String?  // "mmHg", "mg/dL", "lbs", "bpm", "%", "°F"
  recordedAt       DateTime
  recordedById     String?
  notes            String?
  sourceDocumentId String?
  createdAt        DateTime @default(now())
}

enum Role {
  PATIENT
  FAMILY_MEMBER
  CAREGIVER
  ADMIN
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  OVERDUE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskCategory {
  MEDICATION
  APPOINTMENT
  EXERCISE
  MEAL
  HYDRATION
  PERSONAL_CARE
  SOCIAL
  OTHER
}

enum DocumentType {
  DISCHARGE_SUMMARY
  PRESCRIPTION
  LAB_RESULTS
  INSURANCE
  OTHER
}

enum NotificationType {
  TASK_REMINDER
  TASK_COMPLETED
  TASK_OVERDUE
  MEDICATION_REFILL
  APPOINTMENT_REMINDER
  SYSTEM
  SHIFT_REQUEST
  SHIFT_APPROVED
  SHIFT_REJECTED
  SHIFT_COVERED
  CARE_REQUEST
  CARE_REQUEST_HANDLED
}

model CareRequest {
  id            String            @id @default(cuid())
  patientId     String
  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  requestedById String
  requestedDate DateTime
  startTime     String
  endTime       String
  urgency       String            @default("NORMAL")
  notes         String?
  status        CareRequestStatus @default(PENDING)
  adminNote     String?
  handledById   String?
  handledAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum CareRequestStatus {
  PENDING
  SCHEDULED
  DECLINED
}

enum ScheduledShiftStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  MISSED
  NEEDS_COVERAGE
}

enum ShiftRequestType {
  DAY_OFF
  COVER_REQUEST
  SWAP_REQUEST
}

enum ShiftRequestStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String   // e.g. "health_metric.read", "shift.clock_in", "document.upload"
  resourceId   String?  // ID of the resource being accessed
  resourceType String?  // "patient", "shift", "document", "health_metric", etc.
  ipAddress    String?
  userAgent    String?
  metadata     Json?    // additional context (non-PHI only)
  createdAt    DateTime @default(now())
}
