generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  role          Role      @default(FAMILY_MEMBER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // App relations
  patient       Patient?  @relation("PatientUser")
  familyOf      Patient[] @relation("FamilyMembers")
  notifications Notification[]
  uploadedDocuments Document[] @relation("UploadedDocuments")
  assignedTasks Task[] @relation("AssignedTasks")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Patient {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation("PatientUser", fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth     DateTime?
  medicalNotes    String?
  emergencyContact String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  familyMembers   User[]       @relation("FamilyMembers")
  tasks           Task[]
  medications     Medication[]
  documents       Document[]
  inviteCodes     InviteCode[]
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy String   // User ID who created the invite
  usedBy    String?  // User ID who used the invite
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Task {
  id          String     @id @default(cuid())
  patientId   String
  patient     Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  dueTime     String?    // Time of day (e.g., "09:00", "14:30")
  isRecurring Boolean    @default(false)
  recurrence  String?    // "daily", "weekly", "monthly"
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(PENDING)
  category    TaskCategory @default(OTHER)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Link to medication if this is a medication task
  medicationId String?
  medication   Medication? @relation(fields: [medicationId], references: [id])

  // Task assignment
  assignedToId String?
  assignedTo   User?      @relation("AssignedTasks", fields: [assignedToId], references: [id])

  notifications Notification[]
}

model Medication {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name         String
  dosage       String
  frequency    String   // "once daily", "twice daily", "every 8 hours", etc.
  instructions String?
  startDate    DateTime
  endDate      DateTime?
  prescriber   String?
  pharmacy     String?
  refillDate   DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Extracted from document
  documentId   String?
  document     Document? @relation(fields: [documentId], references: [id])

  tasks        Task[]
}

model Document {
  id            String       @id @default(cuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fileName      String
  fileUrl       String
  fileType      String
  rawText       String? // OCR extracted text
  processedData Json?        // Structured data extracted from OCR
  summary       String?      // AI-generated plain-English summary
  documentType  DocumentType @default(OTHER)
  uploadedAt    DateTime     @default(now())
  processedAt   DateTime?

  // Who uploaded the document
  uploadedById  String?
  uploadedBy    User?        @relation("UploadedDocuments", fields: [uploadedById], references: [id])

  medications   Medication[]
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?            @relation(fields: [taskId], references: [id])
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  sentAt    DateTime         @default(now())
  readAt    DateTime?

  // Delivery status
  emailSent Boolean @default(false)
  pushSent  Boolean @default(false)
}

enum Role {
  PATIENT
  FAMILY_MEMBER
  CAREGIVER
  ADMIN
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  OVERDUE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskCategory {
  MEDICATION
  APPOINTMENT
  EXERCISE
  MEAL
  HYDRATION
  PERSONAL_CARE
  SOCIAL
  OTHER
}

enum DocumentType {
  DISCHARGE_SUMMARY
  PRESCRIPTION
  LAB_RESULTS
  INSURANCE
  OTHER
}

enum NotificationType {
  TASK_REMINDER
  TASK_COMPLETED
  TASK_OVERDUE
  MEDICATION_REFILL
  APPOINTMENT_REMINDER
  SYSTEM
}
