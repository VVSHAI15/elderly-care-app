# Database
DATABASE_URL="postgresql://user:password@localhost:5432/elderly_care_db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-generate-with-openssl-rand-base64-32"

# Pusher (Real-time notifications)
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_SECRET="your-pusher-secret"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# Resend (Email notifications)
RESEND_API_KEY="re_your-resend-api-key"

# Firebase (Push notifications)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Firebase private key here\n-----END PRIVATE KEY-----"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI
OPENAI_API_KEY="sk-proj-..."

# Capacitor (Mobile)
# For local dev: http://localhost:3000 (simulator) or http://192.168.x.x:3000 (physical device)
# For production: set to your Vercel URL
CAPACITOR_SERVER_URL="http://localhost:3000"
